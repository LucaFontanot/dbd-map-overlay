{
  "name": "dbd-map",
  "version": "1.6.2",
  "description": "Overlay for DBD maps",
  "main": "index.js",
  "author": "Luca <admin@lucaservers.com>",
  "scripts": {
    "start": "electron index.js",
    "prebuild": "bash scripts/prebuild.sh",
    "build": "npm run prebuild && electron-builder -wl",
    "build:win": "npm run prebuild && electron-builder -w",
    "build:linux": "npm run prebuild && electron-builder -l",
    "publish": "npm run prebuild && electron-builder -wl --publish always",
    "publish:win": "npm run prebuild && electron-builder -w --publish always",
    "publish:linux": "npm run prebuild && electron-builder -l --publish always"
  },
  "keywords": [],
  "license": "ISC",
  "build": {
    "productName": "Dbd Map Overlay",
    "appId": "com.github.lucafontanot.dbdmapoverlay",
    "linux": {
      "target": [
        "deb",
        "rpm",
        "AppImage"
      ],
      "category": "Games"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "files": [
      "!static/*",
      "!scripts/*",
      "!dist/*",
      "!maps/*",
      "!.idea/*",
      "!.github/*",
      "!.vscode/*",
      "!.yarn/*"
    ],
    "asarUnpack": [
      "node_modules/tesseract.js/**",
      "node_modules/tesseract.js-core/**",
      "node_modules/sharp/**",
      "node_modules/@img/**",
      "node_modules/node-screenshots/**/*.node",
      "node_modules/node-screenshots-*/**/*.node"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "axios": "^1.13.5",
    "bootstrap": "^5.3.8",
    "cron": "^4.4.0",
    "electron-updater": "^6.7.3",
    "image-size": "^2.0.2",
    "jquery": "^4.0.0",
    "marked": "^17.0.2",
    "node-screenshots": "^0.2.8",
    "popper.js": "^1.16.1",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "uuid": "^13.0.0"
  },
  "optionalDependencies": {
    "@img/sharp-libvips-win32-x64": "^1.2.4",
    "@img/sharp-win32-x64": "^0.34.5"
  }
}
